{
  "name": "finflow",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check --fix --unsafe",
    "check:ts": "tsc --noEmit -p tsconfig.json",
    "gen:pwa-assets": "pwa-assets-generator",
    "gen:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@legendapp/state": "3.0.0-beta.30",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/postgrest-js": "1.19.2",
    "@supabase/supabase-js": "^2.49.1",
    "@tailwindcss/postcss": "^4.0.17",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/query-sync-storage-persister": "^5.69.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-persist-client": "^5.69.0",
    "@tanstack/react-router": "^1.114.3",
    "@tanstack/react-router-devtools": "^1.114.3",
    "@tanstack/router-plugin": "^1.114.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.483.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.14",
    "tw-animate-css": "^1.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@csstools/postcss-oklab-function": "^4.0.8",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lightningcss": "^1.29.3",
    "lint-staged": "^15.5.0",
    "postcss": "^8.5.3",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.0.5",
    "web-vitals": "^4.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css}": [
      "pnpm check"
    ],
    "*.{ts,tsx}": [
      "sh -c tsc --noEmit"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}
